# ── Line ending normalization ──
# Ensures shell scripts / Dockerfiles always have LF endings,
# even when cloned on Windows.  Without this, Docker builds
# fail with "/bin/bash^M: bad interpreter" errors.

* text=auto

# Force LF for files that run inside Linux containers
*.sh        text eol=lf
*.bash      text eol=lf
*.py        text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.css       text eol=lf
*.md        text eol=lf
*.conf      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.toml      text eol=lf
*.mako      text eol=lf
*.env       text eol=lf

# Keep Windows batch files with CRLF
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binary files – do not touch
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
